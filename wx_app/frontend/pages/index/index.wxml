<view style="padding: 10px;">
    <button class = "img_btn" style="width:100%;height: 100px;color: rgb(107, 107, 106);line-height: 100px;" bindtap="chooseImage">选择图片</button>
    <block wx:for="{{imageSrcs}}" wx:key="index"  style="width: 100%;height: fit-content;margin-top: 5px;">
      <image src="{{item}}" bindlongpress="DeleteImg" bindtap="PreviewImg" data-index="{{index}}" style="width:33.33333333%;height:200rpx;display: inline-block;"></image>
    </block>
  <view class="section">
      <view class="section__title">文本类型</view>
      <picker mode="selector" value="{{text_type_index}}" range="{{text_type_list}}" bindchange="text_type">
        <view class="picker">{{text_type_list[text_type_index]}}</view>
      </picker>
    </view>

    <view class="section">
      <view class="section__title">情绪</view>
      <picker mode="selector" value="{{emotion_index}}" range="{{emotion_list}}" bindchange="emotion">
        <view class="picker">{{emotion_list[emotion_index]}}</view>
      </picker>
    </view>
  <button style="width: 100%;font-size: medium;background-color: deepskyblue;" bindtap="call_api">生成朋友圈配文</button>
  <view style="width: 100%;">
    <label style="display: block;margin-top: 10px;margin-bottom: 16rpx;">结果</label>
    <view style="height:auto;min-height:30px;border: darkgray solid 1px;border-radius: 3px;overflow: hidden;padding: 5px;">{{weixin_txt}}</view>
  </view>
</view>